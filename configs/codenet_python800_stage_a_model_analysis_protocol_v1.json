      "same_scale_for_every_geometry_cell": true,
      "pair_local_projection_or_normalization": false
    },
    "sinkhorn_scale": {
      "reference_cell": "EEE_true_LCA",
      "cost_scale": "median_of_positive_pairwise_cost_medians_on_the_same_4096_training_pairs",
      "kappa": 0.05,
      "epsilon": "max(kappa*cost_scale,1e-6)",
      "same_epsilon_for_every_cell_within_a_seed": true,
      "pair_local_cost_normalization": false
    }
